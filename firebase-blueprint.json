{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "lastSeen": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation (1-on-1 or group)",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["direct", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "lastMessageId": { "type": "string" },
        "name": { "type": "string" },
        "groupAvatar": { "type": "string" },
        "adminIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "participants", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "file"] },
        "createdAt": { "type": "number" },
        "editedAt": { "type": "number" },
        "deletedAt": { "type": "number" },
        "attachments": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["chatId", "senderId", "createdAt", "type"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Conversations list"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages inside a conversation"
    }
  }
}
